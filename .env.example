PORT=5000
NODE_ENV=development
TRUST_PROXY=1
CLIENT_ORIGIN=http://localhost:5174
# Optional backward-compatible alias:
# CLIENT_URL=http://localhost:5174
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30

# Production SQL Server mode
DB_CLIENT=sqlserver
DATABASE_URL=sqlserver://SERVER_NAME;database=DATABASE_NAME;user=USERNAME;password=PASSWORD;trustServerCertificate=true
SQLSERVER_HOST=SERVER_NAME
SQLSERVER_PORT=1433
SQLSERVER_USER=USERNAME
SQLSERVER_PASSWORD=replace-with-strong-password
SQLSERVER_DATABASE=DATABASE_NAME
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_SERVER_CERTIFICATE=true
SQLSERVER_POOL_MAX=10
SQLSERVER_REQUEST_TIMEOUT_MS=15000

# Legacy/dev fallback mode
MONGO_URI=mongodb://127.0.0.1:27017/razk-automation-hrms
ALLOW_LOCAL_STORE=true

EMAIL_USER=
EMAIL_PASS=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
