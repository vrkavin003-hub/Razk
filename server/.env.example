PORT=5000
NODE_ENV=development
TRUST_PROXY=1
CLIENT_ORIGIN=http://localhost:5174
# Optional backward-compatible alias:
# CLIENT_URL=http://localhost:5174
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30

# MongoDB (supported production database)
MONGO_URI=mongodb://127.0.0.1:27017/razk-automation-hrms
MONGO_POOL_SIZE=25
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=3000
MONGO_CREATE_INDEXES=true

# Local JSON fallback is development-only. Render must use false.
ALLOW_LOCAL_STORE=true

# Production attendance/document storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_UPLOAD_BYTES=5242880
UPLOAD_TIMEOUT_MS=30000

# Optional monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# First production deploy only; remove after changing the bootstrap admin password.
DEFAULT_ADMIN_PASSWORD=

# Per-subject/user rate limits
GENERAL_RATE_LIMIT_MAX=3000
GENERAL_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=15
LOGIN_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_RESET_RATE_LIMIT_MAX=10
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
UPLOAD_RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_WINDOW_MS=3600000

EMAIL_USER=
EMAIL_PASS=

# Optional legacy SQL Server mode; MongoDB remains the documented production path.
# DB_CLIENT=sqlserver
# DATABASE_URL=sqlserver://SERVER_NAME;database=DATABASE_NAME;user=USERNAME;password=PASSWORD;trustServerCertificate=true
