PORT=5000
CLIENT_ORIGIN=http://localhost:5174
# Optional backward-compatible alias:
# CLIENT_URL=http://localhost:5174
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30

# Production SQL mode
DB_CLIENT=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=hyatech_user
MYSQL_PASSWORD=replace-with-strong-password
MYSQL_DATABASE=hyatech_db
MYSQL_CONNECTION_LIMIT=10

# Legacy/dev fallback mode
MONGO_URI=mongodb://127.0.0.1:27017/hya-tech-hrms
ALLOW_LOCAL_STORE=true

EMAIL_USER=
EMAIL_PASS=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
MAX_RESUME_BYTES=5242880
