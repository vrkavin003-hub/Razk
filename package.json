{
  "name": "razk-automation-employee-management-system",
  "version": "1.0.0",
  "private": true,
  "description": "Root launcher for Razk Automation HRMS client and server",
  "scripts": {
    "dev": "node scripts/start-dev.js",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "test:attendance": "node tests/integration/attendance-local.js",
    "test:attendance-photo": "node tests/unit/attendance-photo.mjs",
    "test:device-persistence": "node tests/unit/device-persistence.mjs",
    "test:upload-streaming": "node tests/unit/upload-streaming.js",
    "load:inspect": "k6 inspect -e K6_VALIDATE_ONLY=true tests/load/razk-50-users.js",
    "load:test": "k6 run tests/load/razk-50-users.js",
    "seed": "npm --prefix server run seed",
    "install:all": "npm --prefix server install && npm --prefix client install"
  }
}
